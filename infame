function goProduct(prodId){
  if(editModeOn)return;
  currentProdId=prodId;
  selectedSize=null;
  const p=store.products.find(x=>x.id===prodId);
  if(!p)return;
  const soldOut=p.stock===0;
  const imgs=p.images.filter(Boolean);
  let activeImg=0;
  function renderImgs(){
    const wrap=document.getElementById('prod-images-wrap');
    wrap.innerHTML=`
      <div style="position:relative;aspect-ratio:4/5;overflow:hidden;background:#080808" id="main-img-slot">
        ${imgs.length?`<img src="${imgs[activeImg]}" id="main-prod-img" style="width:100%;height:100%;object-fit:cover">`:`<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#1a1a1a;font-size:10px;letter-spacing:.2em;flex-direction:column;gap:10px"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>SIN IMAGEN</div>`}
      </div>
      ${imgs.length>1?`<div class="thumbs">${imgs.map((img,i)=>`<div class="thumb${i===activeImg?' active':''}" onclick="switchImg(${i})" id="thumb-${i}"><img src="${img}" loading="lazy"></div>`).join('')}</div>`:''}`;
  }
  window.switchImg=function(i){
    activeImg=i;
    const mi=document.getElementById('main-prod-img');
    if(mi)mi.src=imgs[i];
    document.querySelectorAll('.thumb').forEach((t,idx)=>t.classList.toggle('active',idx===i));
  };
  renderImgs();
  document.getElementById('prod-detail-name').textContent=p.name;
  document.getElementById('prod-detail-price').textContent=`$${p.price.toLocaleString()} MXN`;
  const descEl=document.getElementById('prod-detail-desc');
  if(p.description){descEl.textContent=p.description;descEl.style.display='block'}else{descEl.style.display='none'}
  document.getElementById('prod-soldout-badge').style.display=soldOut?'block':'none';
  document.getElementById('prod-stock-text').textContent=soldOut?'Sin stock':`${p.stock} disponible${p.stock!==1?'s':''}`;
  const sizesWrap=document.getElementById('prod-sizes');
  document.getElementById('prod-size-label').textContent='Talla';
  sizesWrap.innerHTML=p.sizes.map(s=>`<button class="size-btn${soldOut?' ':''}${selectedSize===s?' sel':''}" onclick="selectSize('${s}',this)"${soldOut?' disabled':''}>${s}</button>`).join('');
  const btns=document.getElementById('prod-btns');
  btns.innerHTML=soldOut
    ?`<button class="wa-btn" disabled style="border-color:#1a1a1a;color:#1a1a1a">Agotado</button>`
    :`<button class="add-btn" onclick="addToCartFromPage()">Agregar al carrito</button>
      <button class="wa-btn" onclick="waFromPage()">Pedir por WhatsApp</button>`;
  document.getElementById('prod-back-btn').onclick=()=>goCategory(p.category);
  goPage('product');
}

window.selectSize=function(s,btn){
