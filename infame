  if(!confirm('¿Eliminar este producto?'))return;
  store.products=store.products.filter(p=>p.id!==id);
  saveStore();renderAdminProducts();renderHomeCats();notify('Producto eliminado');
};
window.addProduct=function(){
  const name=document.getElementById('np-name').value.trim();
  const price=parseInt(document.getElementById('np-price').value)||0;
  const stock=parseInt(document.getElementById('np-stock').value)||0;
  const sizes=document.getElementById('np-sizes').value.split(',').map(s=>s.trim()).filter(Boolean);
  const category=document.getElementById('np-category').value;
  const desc=document.getElementById('np-desc').value.trim();
  if(!name||!price){alert('Escribe nombre y precio');return;}
  store.products.push({id:'p'+Date.now(),name,price,stock,sizes:sizes.length?sizes:['ONE SIZE'],category,description:desc,hidden:false,images:[null,null,null]});
  saveStore();renderAdminProducts();renderHomeCats();
  ['np-name','np-price','np-stock','np-sizes','np-desc'].forEach(id=>document.getElementById(id).value='');
  notify('Producto agregado');
};

// ─ EDIT MODAL ─
window.openEditModal=function(id){
  editingProdId=id;
  const p=store.products.find(x=>x.id===id);if(!p)return;
  document.getElementById('ep-name').value=p.name;
  document.getElementById('ep-price').value=p.price;
  document.getElementById('ep-stock').value=p.stock;
  document.getElementById('ep-sizes').value=p.sizes.join(',');
  document.getElementById('ep-desc').value=p.description||'';
  document.getElementById('ep-hidden').checked=p.hidden;
  renderCategorySelects();
  document.getElementById('ep-category').value=p.category;
  [0,1,2].forEach(i=>renderSlot(i,p.images[i]));
  document.getElementById('edit-modal').classList.add('open');
  window.scrollTo(0,0);
};
window.closeEditModal=function(){document.getElementById('edit-modal').classList.remove('open');editingProdId=null};
function renderSlot(i,src){
  const slot=document.getElementById('slot-'+i);if(!slot)return;
  slot.innerHTML=src
    ?`<img src="${src}" style="width:100%;height:100%;object-fit:cover">`
    :`<div class="ph"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>Foto ${i+1}</div>`;
}
window.uploadProdImg=function(input,i){
  if(!input.files[0]||!editingProdId)return;
  readFile(input.files[0],data=>{
    store.products=store.products.map(p=>p.id===editingProdId?{...p,images:p.images.map((img,idx)=>idx===i?data:img)}:p);
    saveStore();renderSlot(i,data);notify('Foto subida');
  });
};
window.removeProdImg=function(i){
  if(!editingProdId)return;
  store.products=store.products.map(p=>p.id===editingProdId?{...p,images:p.images.map((img,idx)=>idx===i?null:img)}:p);
  saveStore();renderSlot(i,null);
};
window.saveEditProduct=function(){
  if(!editingProdId)return;
  const sizes=document.getElementById('ep-sizes').value.split(',').map(s=>s.trim()).filter(Boolean);
  store.products=store.products.map(p=>p.id===editingProdId?{
    ...p,
    name:document.getElementById('ep-name').value.trim(),
    price:parseInt(document.getElementById('ep-price').value)||p.price,
    stock:parseInt(document.getElementById('ep-stock').value)||0,
    sizes:sizes.length?sizes:p.sizes,
    category:document.getElementById('ep-category').value,
    description:document.getElementById('ep-desc').value.trim(),
    hidden:document.getElementById('ep-hidden').checked
  }:p);
  saveStore();
  renderAdminProducts();renderHomeCats();closeEditModal();notify('Producto guardado');
  // Refresh category page if open
  if(document.getElementById('page-category').classList.contains('active'))
    renderCategoryPage(currentCatId);
};

// ─ CATEGORY CRUD ─
window.updateCatName=function(id,val){
  store.categories=store.categories.map(c=>c.id===id?{...c,name:val}:c);
  saveStore();renderHomeCats();renderMenuCats();
};
window.uploadCatImg=function(input,id){
  if(!input.files[0])return;
  readFile(input.files[0],data=>{
    store.categories=store.categories.map(c=>c.id===id?{...c,image:data}:c);
    saveStore();renderHomeCats();notify('Foto de categoría actualizada');
  });
};
window.deleteCat=function(id){
  if(!confirm('¿Eliminar esta categoría?'))return;
  store.categories=store.categories.filter(c=>c.id!==id);
  saveStore();renderAdminCategories();renderHomeCats();renderMenuCats();renderCategorySelects();notify('Categoría eliminada');
};
window.addCategory=function(){
  const name=document.getElementById('new-cat-name').value.trim();
  if(!name)return;
  store.categories.push({id:'cat'+Date.now(),name,image:null});
  saveStore();renderAdminCategories();renderHomeCats();renderMenuCats();renderCategorySelects();
  document.getElementById('new-cat-name').value='';notify('Categoría agregada');
};

// ═══════════════════════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════════════════════
function readFile(file,cb){
  const reader=new FileReader();
  reader.onload=e=>cb(e.target.result);
  reader.readAsDataURL(file);
}
let notifTimer;
function notify(msg){
  const el=document.getElementById('notif');
  el.textContent=msg;el.style.display='block';
  clearTimeout(notifTimer);
  notifTimer=setTimeout(()=>{el.style.display='none'},2200);
}
</script>
