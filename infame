// Update a simple field inline
window.ieUpdateField=function(id,field,val){
  store.products=store.products.map(p=>{
    if(p.id!==id)return p;
    const updated={...p};
    if(field==='price')updated.price=parseInt(val)||p.price;
    else if(field==='stock')updated.stock=parseInt(val)||0;
    else updated[field]=val;
    return updated;
  });
  saveStore();
  // Update displayed text without full re-render
  const pn=document.getElementById('pname-'+id);
  const pp=document.getElementById('pprice-'+id);
  const prod=store.products.find(x=>x.id===id);
  if(pn&&field==='name')pn.textContent=val;
  if(pp&&field==='price')pp.textContent=`$${prod.price.toLocaleString()} MXN`;
};

window.ieUpdateSizes=function(id,val){
  const sizes=val.split(',').map(s=>s.trim()).filter(Boolean);
  store.products=store.products.map(p=>p.id===id?{...p,sizes:sizes.length?sizes:p.sizes}:p);
  saveStore();
};

window.ieToggleHide=function(id){
  store.products=store.products.map(p=>p.id===id?{...p,hidden:!p.hidden}:p);
  saveStore();
  // Remove card from grid if now hidden
  const card=document.getElementById('pc-'+id);
  if(card)card.style.opacity='0.3';
  renderHomeCats();
  notify('Visibilidad actualizada');
};

window.ieDel=function(id){
  if(!confirm('¿Eliminar este producto?'))return;
  store.products=store.products.filter(p=>p.id!==id);
  saveStore();
  renderCategoryPage(currentCatId);
  renderHomeCats();
  notify('Producto eliminado');
};

// Cycle through image slots — opens file picker
window.ieCycleProdImg=function(id){
  if(!editModeOn)return;
  catProdImgTarget={prodId:id,slotIndex:0};
  document.getElementById('cat-prod-img-input').click();
};

window.handleCatProdImgUpload=function(input){
  if(!input.files[0]||!catProdImgTarget)return;
  readFile(input.files[0],data=>{
    const{prodId,slotIndex}=catProdImgTarget;
    store.products=store.products.map(p=>{
      if(p.id!==prodId)return p;
      const imgs=[...p.images];
      imgs[slotIndex]=data;
      return{...p,images:imgs};
    });
    saveStore();
    // Update card image
    const card=document.getElementById('pc-'+prodId);
    if(card){
      const imgEl=card.querySelector('.prod-img-wrap img');
      const phEl=card.querySelector('.prod-ph');
      if(imgEl){imgEl.src=data}
      else if(phEl){
        phEl.outerHTML=`<img src="${data}" alt="" style="width:100%;height:100%;object-fit:cover;filter:brightness(.85)">`;
      }
    }
    input.value='';
    catProdImgTarget=null;
    notify('Foto actualizada');
  });
};

