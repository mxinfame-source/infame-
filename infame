function renderAll(){
  renderBrand();renderLogo();renderHero();renderHomeCats();renderMenuCats();renderAdminGeneral();
}
function renderBrand(){
  const b=store.brandName||'INFAME';
  document.getElementById('logo-text').textContent=b;
  document.getElementById('menu-brand').textContent=b;
  document.getElementById('footer-brand').textContent=b;
  const ab=document.getElementById('admin-brand-display');if(ab)ab.textContent=b;
}
function renderLogo(){
  const img=document.getElementById('logo-img'),txt=document.getElementById('logo-text');
  if(store.logo){img.src=store.logo;img.style.display='block';txt.style.display='none'}
  else{img.style.display='none';txt.style.display='block'}
}
function renderHero(){
  const ph=document.getElementById('hero-placeholder'),img=document.getElementById('hero-img');
  if(store.heroImage){img.src=store.heroImage;img.style.display='block';ph.style.display='none'}
  else{img.style.display='none';ph.style.display='flex'}
  document.getElementById('hero-title-text').textContent=store.heroText||'NUEVA COLECCIÓN';
}
function renderHomeCats(){
  const grid=document.getElementById('home-cats');
  grid.innerHTML=store.categories.map(c=>{
    const count=store.products.filter(p=>!p.hidden&&p.category===c.id).length;
    return`<div class="cat-card" onclick="goCategory('${c.id}')">
      ${c.image?`<img src="${c.image}" alt="${c.name}">`:`<div class="cat-ph"></div>`}
      <div class="cat-info"><div class="cat-name">${c.name}</div><div class="cat-count">${count} prenda${count!==1?'s':''}</div></div>
    </div>`;
  }).join('');
}
function renderMenuCats(){
  document.getElementById('menu-cats').innerHTML=store.categories.map(c=>
    `<button class="menu-item" onclick="goCategory('${c.id}')">${c.name}</button>`
  ).join('');
}

// ═══════════════════════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════════════════════
function goPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const p=document.getElementById('page-'+id);
  if(p){p.classList.add('active');p.classList.add('anim-fade')}
  window.scrollTo(0,0);
  closeMenu();
}
function goCategory(catId){
  currentCatId=catId;
  const cat=store.categories.find(c=>c.id===catId);
  document.getElementById('cat-page-title').textContent=catId==='all'?'Todo':(cat?cat.name:catId);
  renderCategoryPage(catId);
  // Show edit bar only if authenticated
  const editBar=document.getElementById('edit-mode-bar');
  editBar.classList.toggle('visible', adminAuthed);
  goPage('category');
}

function renderCategoryPage(catId){
  const bar=document.getElementById('cat-filter-bar');
  bar.innerHTML=[{id:'all',name:'Todo'},...store.categories].map(c=>
    `<button class="cat-filter-btn${c.id===catId?' active':''}" onclick="goCategory('${c.id}')">${c.name}</button>`
  ).join('');
  const prods=catId==='all'
    ?store.products.filter(p=>!p.hidden)
    :store.products.filter(p=>!p.hidden&&p.category===catId);
  document.getElementById('cat-page-count').textContent=`${prods.length} prenda${prods.length!==1?'s':''}`;

  if(prods.length===0){
    document.getElementById('cat-products').innerHTML=
      `<div style="padding:60px 20px;text-align:center;font-size:11px;color:#222;grid-column:span 2">Sin productos en esta categoría</div>`;
    return;
  }

  document.getElementById('cat-products').innerHTML=prods.map(p=>buildProdCard(p)).join('');
}

function buildProdCard(p){
  // Inline edit panel HTML
  const iePanel=`
    <div class="inline-edit-panel" onclick="event.stopPropagation()">
      <div class="ie-row">
        <div style="flex:1">
          <span class="ie-label">Nombre</span>
          <input class="ie-input" value="${escHtml(p.name)}" onchange="ieUpdateField('${p.id}','name',this.value)" style="width:100%">
        </div>
      </div>
      <div class="ie-row">
        <div style="flex:1">
          <span class="ie-label">Precio MXN</span>
          <input class="ie-input" type="number" value="${p.price}" onchange="ieUpdateField('${p.id}','price',this.value)" style="width:100%">
        </div>
        <div style="width:72px">
          <span class="ie-label">Stock</span>
          <input class="ie-input" type="number" value="${p.stock}" onchange="ieUpdateField('${p.id}','stock',this.value)" style="width:100%">
        </div>
      </div>
      <div class="ie-row">
        <div style="flex:1">
          <span class="ie-label">Tallas (coma)</span>
          <input class="ie-input" value="${escHtml(p.sizes.join(','))}" onchange="ieUpdateSizes('${p.id}',this.value)" style="width:100%">
        </div>
      </div>
      <div class="ie-actions">
        <button class="ie-btn" onclick="ieCycleProdImg('${p.id}')">📷 Foto</button>
        <button class="ie-btn" onclick="ieToggleHide('${p.id}')">${p.hidden?'Mostrar':'Ocultar'}</button>
        <button class="ie-btn" onclick="openEditModal('${p.id}')">Editar completo</button>
        <button class="ie-btn danger" onclick="ieDel('${p.id}')">Eliminar</button>
      </div>
    </div>`;

  return`<div class="prod-card" id="pc-${p.id}" onclick="editModeOn?null:goProduct('${p.id}')">
    <div class="prod-img-wrap" onclick="editModeOn&&ieCycleProdImg('${p.id}')">
      ${p.images[0]?`<img src="${p.images[0]}" alt="${escHtml(p.name)}" loading="lazy">`:`<div class="prod-ph"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div>`}
      ${p.stock===0?`<span class="sold-badge">Agotado</span>`:''}
    </div>
    <div class="prod-info">
      <p class="prod-name" id="pname-${p.id}">${escHtml(p.name)}</p>
      <p class="prod-price" id="pprice-${p.id}">$${p.price.toLocaleString()} MXN</p>
    </div>
    ${iePanel}
  </div>`;
}

function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

