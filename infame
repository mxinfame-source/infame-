<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#000000">
<title>INFAME</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;1,300&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  html{scroll-behavior:smooth;background:#000}
  body{background:#000;color:#fff;font-family:'Space Mono',monospace;overflow-x:hidden;min-height:100vh}
  ::-webkit-scrollbar{width:2px}::-webkit-scrollbar-track{background:#000}::-webkit-scrollbar-thumb{background:#1a1a1a}
  img{display:block;max-width:100%}
  button,input,select,textarea{font-family:'Space Mono',monospace;outline:none}
  .serif{font-family:'Cormorant',serif}
  @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  @keyframes slideRight{from{transform:translateX(100%)}to{transform:translateX(0)}}
  @keyframes slideLeft{from{transform:translateX(-100%)}to{transform:translateX(0)}}
  @keyframes fadeIn{from{opacity:0}to{opacity:1}}
  .anim-fade{animation:fadeUp .35s ease forwards}
  .anim-slide{animation:slideRight .3s ease forwards}
  .anim-slideL{animation:slideLeft .3s ease forwards}

  /* ─ NAV ─ */
  #nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:15px 20px;background:rgba(0,0,0,.96);border-bottom:1px solid #111}
  #nav-logo{cursor:pointer;display:flex;align-items:center}
  #nav-logo img{height:28px;object-fit:contain}
  #nav-logo span{font-family:'Cormorant',serif;font-size:22px;font-weight:300;letter-spacing:.3em;color:#fff}
  .nav-right{display:flex;align-items:center;gap:18px}
  .icon-btn{background:transparent;border:none;color:#fff;cursor:pointer;padding:4px;position:relative;line-height:0}
  .cart-badge{position:absolute;top:-4px;right:-4px;background:#fff;color:#000;border-radius:50%;width:14px;height:14px;font-size:8px;display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace}

  /* ─ PAGES ─ */
  .page{min-height:100vh;padding-top:57px;display:none}
  .page.active{display:block}

  /* ─ HERO ─ */
  #hero-wrap{position:relative;height:calc(100svh - 57px);overflow:hidden;background:#0a0a0a}
  #hero-img{width:100%;height:100%;object-fit:cover;filter:brightness(.65)}
  #hero-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#080808;flex-direction:column;gap:12px;color:#1a1a1a;font-size:10px;letter-spacing:.25em;text-transform:uppercase}
  .hero-overlay{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:32px 24px}
  .hero-label{font-size:9px;letter-spacing:.3em;color:#666;text-transform:uppercase;margin-bottom:8px}
  .hero-title{font-family:'Cormorant',serif;font-size:clamp(36px,10vw,80px);font-weight:300;letter-spacing:.1em;line-height:1;margin-bottom:24px}
  .view-all-btn{align-self:flex-start;background:transparent;border:1px solid rgba(255,255,255,.4);color:#fff;padding:10px 22px;font-size:9px;letter-spacing:.25em;text-transform:uppercase;cursor:pointer;transition:border-color .2s,color .2s}
  .view-all-btn:hover{border-color:#fff}

  /* ─ SECTION ─ */
  .section-pad{padding:44px 20px 0}
  .section-label{font-size:8px;letter-spacing:.35em;color:#333;text-transform:uppercase;margin-bottom:22px}
  .divider{height:1px;background:#0d0d0d;margin:0 20px}

  /* ─ CAT GRID ─ */
  .cat-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:#111}
  .cat-card{background:#000;cursor:pointer;position:relative;aspect-ratio:3/4;overflow:hidden}
  .cat-card img{width:100%;height:100%;object-fit:cover;filter:brightness(.55);transition:transform .5s ease}
  .cat-card:hover img{transform:scale(1.03)}
  .cat-ph{width:100%;height:100%;background:#080808;display:flex;align-items:center;justify-content:center}
  .cat-info{position:absolute;bottom:12px;left:12px}
  .cat-name{font-family:'Cormorant',serif;font-size:20px;font-weight:300;letter-spacing:.12em}
  .cat-count{font-size:8px;color:#555;letter-spacing:.2em;margin-top:2px}

  /* ─ PROD GRID ─ */
  .prod-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:#111}
  .prod-card{background:#000;cursor:pointer;position:relative}
  .prod-img-wrap{position:relative;aspect-ratio:3/4;overflow:hidden;background:#0a0a0a}
  .prod-img-wrap img{width:100%;height:100%;object-fit:cover;filter:brightness(.85);transition:transform .5s}
  .prod-card:hover .prod-img-wrap img{transform:scale(1.03)}
  .prod-ph{width:100%;height:100%;background:#080808;display:flex;align-items:center;justify-content:center;color:#1a1a1a;font-size:9px;letter-spacing:.2em;text-transform:uppercase}
  .sold-badge{position:absolute;top:8px;right:8px;background:#000;border:1px solid #222;font-size:7px;letter-spacing:.2em;padding:3px 7px;text-transform:uppercase;color:#444}
  .prod-info{padding:10px 10px 14px}
  .prod-name{font-size:9px;letter-spacing:.18em;text-transform:uppercase;margin-bottom:4px}
  .prod-price{font-size:12px;color:#888;letter-spacing:.1em}

  /* ─ INLINE EDIT MODE ─ */
  .edit-mode-bar{display:none;align-items:center;justify-content:space-between;padding:10px 16px;background:#0d0d0d;border-bottom:1px solid #1a1a1a;position:sticky;top:57px;z-index:90}
  .edit-mode-bar.visible{display:flex}
  .edit-mode-label{font-size:8px;letter-spacing:.25em;text-transform:uppercase;color:#888}
  .edit-mode-toggle{display:flex;gap:6px;align-items:center}
  .toggle-pill{width:32px;height:18px;background:#1a1a1a;border-radius:9px;cursor:pointer;border:none;position:relative;transition:background .2s;flex-shrink:0}
  .toggle-pill::after{content:'';position:absolute;top:3px;left:3px;width:12px;height:12px;background:#444;border-radius:50%;transition:transform .2s,background .2s}
  .toggle-pill.on{background:#fff}
  .toggle-pill.on::after{transform:translateX(14px);background:#000}
  .toggle-label{font-size:8px;letter-spacing:.2em;text-transform:uppercase;color:#444;cursor:pointer}
  .toggle-label.on{color:#fff}

  /* prod card in edit mode */
  body.editing .prod-card{cursor:default}
  body.editing .prod-card .prod-img-wrap{cursor:pointer}
  .prod-card .inline-edit-panel{display:none;background:#060606;border-top:1px solid #111;padding:10px 10px 12px}
  body.editing .prod-card .inline-edit-panel{display:block}
  .ie-row{display:flex;gap:6px;margin-bottom:6px}
  .ie-input{flex:1;background:transparent;border:none;border-bottom:1px solid #1a1a1a;color:#fff;padding:4px 0;font-size:10px;font-family:'Space Mono',monospace;min-width:0}
  .ie-input:focus{border-bottom-color:#555}
  .ie-label{font-size:7px;letter-spacing:.2em;color:#333;text-transform:uppercase;display:block;margin-bottom:3px}
  .ie-btn{background:transparent;border:1px solid #222;color:#888;font-size:7px;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;padding:4px 8px;font-family:'Space Mono',monospace;transition:all .15s;white-space:nowrap}
  .ie-btn:hover{border-color:#555;color:#fff}
  .ie-btn.danger{border-color:#c44;color:#c44}
  .ie-btn.primary{background:#fff;color:#000;border-color:#fff}
  .ie-actions{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px}

  /* img upload overlay in edit mode */
  body.editing .prod-img-wrap{position:relative}
  body.editing .prod-img-wrap::after{content:'TAP PARA\ACAMBIAR FOTO';white-space:pre;position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:7px;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.25);background:rgba(0,0,0,.4);pointer-events:none;line-height:1.8;text-align:center}
  .cat-img-upload-input{display:none}

  /* ─ PRODUCT PAGE ─ */
  .prod-main-img{width:100%;aspect-ratio:4/5;object-fit:cover;background:#0a0a0a}
  .thumbs{display:flex;gap:4px;padding:8px 12px;background:#000}
  .thumb{width:52px;height:66px;cursor:pointer;border:1px solid #1a1a1a;overflow:hidden;background:#111;transition:border-color .2s}
  .thumb.active{border-color:#fff}
  .thumb img{width:100%;height:100%;object-fit:cover}
  .prod-detail{padding:24px 20px 40px}
  .prod-big-name{font-family:'Cormorant',serif;font-size:28px;font-weight:300;letter-spacing:.1em;margin-bottom:6px}
  .prod-big-price{font-size:16px;color:#aaa;letter-spacing:.08em;margin-bottom:18px}
  .prod-desc{font-size:11px;color:#444;line-height:1.7;letter-spacing:.04em;margin-bottom:20px}
  .size-label{font-size:8px;letter-spacing:.25em;color:#333;text-transform:uppercase;margin-bottom:10px}
  .sizes-wrap{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
  .size-btn{padding:8px 14px;font-size:9px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;background:transparent;color:#fff;border:1px solid #222;transition:all .15s}
  .size-btn.sel{background:#fff;color:#000;border-color:#fff}
  .size-btn:disabled{opacity:.3;cursor:not-allowed}
  .stock-text{font-size:8px;color:#333;letter-spacing:.15em;text-transform:uppercase;margin-bottom:18px}
  .add-btn{width:100%;padding:14px;background:#fff;color:#000;border:none;font-size:10px;letter-spacing:.25em;text-transform:uppercase;cursor:pointer;margin-bottom:10px;transition:opacity .2s}
  .add-btn:hover{opacity:.85}
  .wa-btn{width:100%;padding:14px;background:transparent;border:1px solid #25D366;color:#25D366;font-size:10px;letter-spacing:.25em;text-transform:uppercase;cursor:pointer;transition:opacity .2s}
  .wa-btn:hover{opacity:.75}
  .prod-meta{margin-top:28px;border-top:1px solid #0d0d0d;padding-top:18px;font-size:8px;color:#2a2a2a;letter-spacing:.15em;line-height:2;text-transform:uppercase}

  /* ─ CART DRAWER ─ */
  #cart-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:299}
  #cart-drawer{position:fixed;right:0;top:0;bottom:0;width:min(360px,100vw);background:#000;border-left:1px solid #111;z-index:300;display:flex;flex-direction:column;padding:20px;transform:translateX(100%);transition:transform .3s ease}
  #cart-drawer.open{transform:translateX(0)}
  .cart-item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #0d0d0d}
  .cart-item-img{width:56px;height:72px;object-fit:cover;background:#0a0a0a;flex-shrink:0}
  .cart-item-img-ph{width:56px;height:72px;background:#0a0a0a;flex-shrink:0;display:flex;align-items:center;justify-content:center}
  .cart-items-scroll{flex:1;overflow-y:auto}
  .cart-footer{border-top:1px solid #111;padding-top:16px;margin-top:8px}
  .cart-total-row{display:flex;justify-content:space-between;margin-bottom:6px}
  .cart-label{font-size:9px;letter-spacing:.2em;color:#333;text-transform:uppercase}
  .cart-total-val{font-size:15px;letter-spacing:.05em}
  .shipping-note{font-size:8px;color:#2a2a2a;letter-spacing:.1em;margin-bottom:14px}
  .shipping-ok{font-size:8px;color:#25D366;letter-spacing:.1em;margin-bottom:14px}
  .qty-btn{background:transparent;border:none;color:#444;cursor:pointer;font-size:16px;padding:0 4px;line-height:1}

  /* ─ CHECKOUT ─ */
  .checkout-pad{padding:28px 20px 60px}
  .form-group{margin-bottom:18px}
  .form-label{font-size:8px;letter-spacing:.25em;color:#333;text-transform:uppercase;display:block;margin-bottom:7px}
  .form-input{width:100%;background:transparent;border:none;border-bottom:1px solid #1a1a1a;color:#fff;padding:8px 0;font-size:14px;transition:border-color .2s}
  .form-input:focus{border-bottom-color:#555}
  .payment-btns{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}
  .pay-btn{padding:8px 14px;font-size:9px;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;background:transparent;color:#fff;border:1px solid #222;transition:all .15s}
  .pay-btn.sel{background:#fff;color:#000;border-color:#fff}
  .order-summary{background:#060606;padding:16px;margin-bottom:28px;border:1px solid #0d0d0d}
  .summary-row{display:flex;justify-content:space-between;margin-bottom:7px;font-size:9px;color:#555;letter-spacing:.08em}
  .summary-total{display:flex;justify-content:space-between;border-top:1px solid #111;padding-top:10px;margin-top:4px}

  /* ─ MENU ─ */
  #menu-overlay{display:none;position:fixed;inset:0;z-index:200;background:#000;flex-direction:column;padding:20px;overflow-y:auto}
  #menu-overlay.open{display:flex}
  .menu-item{font-family:'Cormorant',serif;font-size:clamp(30px,9vw,56px);font-weight:300;letter-spacing:.08em;color:#fff;padding:10px 0;cursor:pointer;border-bottom:1px solid #0d0d0d;background:transparent;border-left:none;border-right:none;border-top:none;text-align:left;width:100%;transition:color .2s}
  .menu-item-sm{font-size:10px;font-family:'Space Mono',monospace;letter-spacing:.2em;color:#333;padding:9px 0;cursor:pointer;background:transparent;border:none;text-align:left;text-transform:uppercase;width:100%}

  /* ─ ADMIN ─ */
  .admin-section{margin-bottom:32px}
  .admin-title{font-size:8px;letter-spacing:.3em;color:#333;text-transform:uppercase;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid #0d0d0d}
  .admin-input{background:transparent;border:1px solid #1a1a1a;color:#fff;padding:9px 12px;font-size:12px;width:100%;margin-bottom:10px;transition:border-color .2s}
  .admin-input:focus{border-color:#444}
  .admin-btn{background:#fff;color:#000;border:none;padding:9px 18px;font-size:9px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;font-family:'Space Mono',monospace}
  .admin-btn-outline{background:transparent;color:#888;border:1px solid #222;padding:7px 13px;font-size:8px;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;font-family:'Space Mono',monospace;transition:border-color .2s}
  .admin-btn-outline:hover{border-color:#555}
  .admin-btn-danger{background:transparent;color:#c44;border:1px solid #c44;padding:7px 13px;font-size:8px;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;font-family:'Space Mono',monospace}
  .admin-tabs{display:flex;border-bottom:1px solid #111;margin-bottom:28px}
  .admin-tab{padding:10px 16px;font-size:8px;letter-spacing:.2em;text-transform:uppercase;background:transparent;border:none;border-bottom:2px solid transparent;color:#333;cursor:pointer;font-family:'Space Mono',monospace;transition:color .2s}
  .admin-tab.active{border-bottom-color:#fff;color:#fff}
  .admin-tab-content{display:none}.admin-tab-content.active{display:block}
  .prod-admin-row{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #080808;align-items:center}
  .prod-admin-thumb{width:52px;height:66px;object-fit:cover;background:#0a0a0a;flex-shrink:0}
  .prod-admin-info{flex:1;min-width:0}
  .prod-admin-actions{display:flex;flex-direction:column;gap:4px;flex-shrink:0}
  .edit-modal{display:none;position:fixed;inset:0;background:#000;z-index:500;overflow-y:auto;padding:20px}
  .edit-modal.open{display:block}
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .img-upload-slot{position:relative;aspect-ratio:3/4;background:#080808;overflow:hidden;margin-bottom:6px;border:1px solid #111}
  .img-upload-slot img{width:100%;height:100%;object-fit:cover}
  .img-upload-slot .ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#1a1a1a;font-size:9px;letter-spacing:.2em;flex-direction:column;gap:8px}
  input[type=file]{display:none}
  .upload-label{display:inline-block;background:transparent;border:1px solid #222;color:#555;padding:5px 12px;font-size:9px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;font-family:'Space Mono',monospace}

  /* ─ NOTIFICATION ─ */
  #notif{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#fff;color:#000;padding:10px 22px;z-index:999;font-size:9px;letter-spacing:.2em;text-transform:uppercase;display:none;white-space:nowrap}

  /* ─ BACK BTN ─ */
  .back-btn{background:transparent;border:none;color:#333;font-size:9px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;font-family:'Space Mono',monospace;display:inline-flex;align-items:center;gap:6px;padding:0;margin-bottom:16px}

  /* ─ FOOTER ─ */
  footer{padding:28px 20px;border-top:1px solid #0a0a0a;display:flex;justify-content:space-between;align-items:center}
  .footer-brand{font-family:'Cormorant',serif;font-size:14px;font-weight:300;letter-spacing:.25em;color:#222}
  .footer-links{display:flex;gap:16px}
  .footer-link{background:transparent;border:none;color:#333;font-size:9px;letter-spacing:.2em;cursor:pointer;font-family:'Space Mono',monospace;text-transform:uppercase}

  /* ─ CAT FILTER BAR ─ */
  .cat-filter-bar{display:flex;overflow-x:auto;border-bottom:1px solid #0d0d0d;scrollbar-width:none}
  .cat-filter-bar::-webkit-scrollbar{display:none}
  .cat-filter-btn{padding:10px 18px;font-size:8px;letter-spacing:.2em;text-transform:uppercase;background:transparent;border:none;border-bottom:2px solid transparent;color:#333;cursor:pointer;white-space:nowrap;font-family:'Space Mono',monospace;transition:color .15s}
  .cat-filter-btn.active{border-bottom-color:#fff;color:#fff}

  /* ─ LOGIN ─ */
  #login-page{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 57px);padding:40px 20px}
  .err-text{font-size:9px;color:#c44;letter-spacing:.1em;margin-bottom:12px}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════ NAV -->
<nav id="nav">
  <div id="nav-logo" onclick="goPage('home')">
    <img id="logo-img" src="" alt="INFAME" style="display:none">
    <span id="logo-text">INFAME</span>
  </div>
  <div class="nav-right">
    <button class="icon-btn" onclick="toggleCart()" id="cart-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-badge" id="cart-count" style="display:none">0</span>
    </button>
    <button class="icon-btn" onclick="openMenu()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════════ MENU -->
<div id="menu-overlay">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32px">
    <span class="serif" style="font-size:22px;font-weight:300;letter-spacing:.3em" id="menu-brand">INFAME</span>
    <button class="icon-btn" onclick="closeMenu()">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <button class="menu-item" onclick="goPage('home')">Todo</button>
  <div id="menu-cats"></div>
  <div style="margin-top:auto;padding-top:24px">
    <button class="menu-item-sm" onclick="window.open('https://instagram.com','_blank')">Instagram ↗</button>
    <button class="menu-item-sm" onclick="window.open('https://wa.me/523322288631','_blank')">WhatsApp ↗</button>
    <button class="menu-item-sm" onclick="closeMenu();toggleCart()">Carrito <span id="menu-cart-count"></span></button>
    <button class="menu-item-sm" style="color:#555;margin-top:12px;border:1px solid #1a1a1a;padding:10px 14px;width:100%;text-align:left" onclick="closeMenu();goAdmin()">⚙ Admin</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ CART -->
<div id="cart-overlay" onclick="toggleCart()"></div>
<div id="cart-drawer">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:22px">
    <span style="font-size:9px;letter-spacing:.3em;text-transform:uppercase" id="cart-title">Carrito</span>
    <button class="icon-btn" onclick="toggleCart()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="cart-items-scroll" id="cart-items"></div>
  <div class="cart-footer" id="cart-footer" style="display:none">
    <div class="cart-total-row">
      <span class="cart-label">Subtotal</span>
      <span class="cart-total-val" id="cart-subtotal">$0</span>
    </div>
    <p class="shipping-note" id="shipping-note"></p>
    <button class="add-btn" id="cart-checkout-btn">Proceder al pago</button>
    <button class="admin-btn-outline" style="width:100%" onclick="clearCart()">Vaciar carrito</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ PAGE: HOME -->
<div class="page active anim-fade" id="page-home">
  <div id="hero-wrap">
    <div id="hero-placeholder"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>IMAGEN PRINCIPAL</div>
