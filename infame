<script>
// ═══════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════
const WA = '523322288631';
let ADMIN_PASS = 'infame2024';
let adminAuthed = false;
let currentCatId = 'all';
let currentProdId = null;
let selectedSize = null;
let selectedPayment = 'Transferencia';
let editingProdId = null;
let editModeOn = false;
let catProdImgTarget = null; // {prodId, slotIndex}

const DEFAULT = {
  brandName:'INFAME', heroText:'NUEVA COLECCIÓN', logo:null, heroImage:null,
  categories:[
    {id:'caps',name:'Caps',image:null},
    {id:'tops',name:'Tops',image:null},
    {id:'hoodies',name:'Hoodies',image:null},
    {id:'bottoms',name:'Bottoms',image:null},
    {id:'ski-masks',name:'Ski Masks',image:null}
  ],
  products:[
    {id:'p1',name:'INFAME CAP 01',category:'caps',price:450,stock:10,hidden:false,sizes:['S/M','L/XL'],images:[null,null,null],description:'6-panel. Bordado frontal. Talla ajustable.'},
    {id:'p2',name:'INFAME HOODIE 01',category:'hoodies',price:890,stock:5,hidden:false,sizes:['S','M','L','XL'],images:[null,null,null],description:'Heavyweight 400gsm. Drop shoulder. Unisex.'},
    {id:'p3',name:'INFAME TOP 01',category:'tops',price:390,stock:8,hidden:false,sizes:['S','M','L','XL'],images:[null,null,null],description:'100% algodón. Corte oversized.'},
    {id:'p4',name:'INFAME SKI MASK 01',category:'ski-masks',price:320,stock:0,hidden:false,sizes:['ONE SIZE'],images:[null,null,null],description:'Acrílico. Knit técnico. Cara completa.'}
  ]
};

function loadStore(){
  try{const s=localStorage.getItem('infame_store');return s?{...DEFAULT,...JSON.parse(s)}:JSON.parse(JSON.stringify(DEFAULT))}catch{return JSON.parse(JSON.stringify(DEFAULT))}
}
function saveStore(){try{localStorage.setItem('infame_store',JSON.stringify(store))}catch{}}
function loadCart(){try{return JSON.parse(localStorage.getItem('infame_cart')||'[]')}catch{return[]}}
function saveCartLocal(){try{localStorage.setItem('infame_cart',JSON.stringify(cart))}catch{}}

let store = loadStore();
